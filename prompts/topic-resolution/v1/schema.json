{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "input_fingerprint", "items"],
  "properties": {
    "schema_version": {"const": 1},
    "input_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "items": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_name", "decision", "topic_id"],
            "properties": {
              "source_name": {"type": "string", "minLength": 1, "maxLength": 40},
              "decision": {"const": "existing"},
              "topic_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_name", "decision", "topic_id", "name", "parent_id",
              "aliases", "definition", "include", "exclude"
            ],
            "properties": {
              "source_name": {"type": "string", "minLength": 1, "maxLength": 40},
              "decision": {"const": "new"},
              "topic_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
              "name": {"type": "string", "minLength": 1, "maxLength": 40},
              "parent_id": {"type": "string", "minLength": 1},
              "aliases": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "definition": {"type": "string", "minLength": 1},
              "include": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "exclude": {"type": "array", "items": {"type": "string", "minLength": 1}}
            }
          }
        ]
      }
    }
  }
}
